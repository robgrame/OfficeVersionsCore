    ViewData["Description"] = "Complete release history of Windows 11 builds and updates. Track version numbers (26H1, 25H2, 24H2, 23H2, 22H2), build numbers, KB articles, and update types (Security, Preview, Out-of-band).";
    ViewData["SeoTitle"] = "Windows 11 Release History - Version Tracker | Build Numbers & KB Articles";
    ViewData["SeoDescription"] = "Track all Windows 11 releases with version numbers (26H1, 25H2, 24H2, 23H2, 22H2, 21H2), build numbers, release dates, KB articles, and update types. Complete update history with latest builds.";
    ViewData["SeoKeywords"] = "Windows 11 releases, Windows 11 versions, Windows 11 build numbers, Windows 11 KB articles, Windows 11 26H1, Windows 11 25H2, Windows 11 24H2, Windows 11 23H2, Windows 11 22H2, Windows 11 updates, Windows 11 update history, Windows 11 security updates, Windows 11 preview updates";
    ViewData["CanonicalUrl"] = "https://www.office365versions.com/windows/releases11";
}

