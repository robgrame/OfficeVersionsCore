{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppConfig": "https://webapps.azconfig.io",
  "Office365": {
    "StoragePath": "content/officeversions",
    "LatestVersionsFile": "m365LatestVersions.json",
    "CurrentChannelFile": "m365CurrentReleases.json",
    "MonthlyEnterpriseChannelFile": "m365MonthlyReleases.json",
    "SemiAnnualChannelFile": "m365SACReleases.json",
    "SemiAnnualPreviewChannelFile": "m365SACPreviewReleases.json",
    "UseLocalStorage": true
  },
  "Office365Scraper": {
    "Enabled": true,
    "intervalMinutes": 10
  },
  "WindowsVersions": {
    "StoragePath": "content/windowsversions",
    "LatestVersionsFile": "windowsLatestVersions.json",
    "UseLocalStorage": true
  },
  "WindowsScraper": {
    "Enabled": true,
    "intervalMinutes": 10
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} <s:{SourceContext}>{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} <s:{SourceContext}>{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "Google": {
    "Tag": "GTM-TBRB6FD"
  },
  "BuyMeACoffee": {
    "Url": "https://buymeacoffee.com/office365versions",
    "Enabled": false
  },
  "SecurityMonitoring": {
    "Enabled": true,
    "CheckIntervalSeconds": 60,
    "AnalysisWindowMinutes": 5,
    "AlertCooldownMinutes": 15,
    "BlockedIpsPersistencePath": "content/security/blocked-ips.json",
    "RequestRate": {
      "WarningPerMinute": 1000,
      "CriticalPerMinute": 5000,
      "MaxPerIpPerMinute": 100
    },
    "AuthFailures": {
      "MaxFailuresPerIpPer5Min": 10,
      "MaxTotalFailuresPer5Min": 50,
      "MaxFailuresPerUserPer5Min": 5
    },
    "ErrorRate": {
      "WarningPercentage": 5.0,
      "CriticalPercentage": 15.0,
      "Max404PerMinute": 50,
      "Max500PerMinute": 10
    },
    "SuspiciousActivity": {
      "EnableBotDetection": true,
      "MaxBotRequestsPerMinute": 200,
      "EnableSqlInjectionDetection": true,
      "EnablePathTraversalDetection": true,
      "MaxSuspiciousRequestsPerMinute": 5,
      "EnableRapidRequestDetection": true,
      "RapidRequestThresholdPerSecond": 50
    },
    "Alerting": {
      "EmailEnabled": true,
      "AlertEmails": [
        "roberto@120magl.com",
        "info@120magl.com"
      ],
      "SmtpHost": "",
      "SmtpPort": 587,
      "SmtpUseSsl": true,
      "SmtpUser": "",
      "SmtpPassword": "",
      "FromEmail": "",
      "TelegramEnabled": true,
      "TelegramBotToken": "",
      "TelegramChatId": "",
      "IncludeDetails": true,
      "AlertLevels": [
        "Warning",
        "Critical"
      ],
      },
    "IpBlocking": {
      "EnableScannerDetection": true,
      "Max404PerIpBeforeBlock": 10,
      "ScannerDetection404BlockMinutes": 120
    },
    "Honeypot": {
      "SuspiciousExtensions": [ ".php", ".asp", ".aspx", ".jsp", ".cgi" ]
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "InstrumentationKey=b88fead2-a685-464d-bfcf-ddc4172fb039;IngestionEndpoint=https://italynorth-0.in.applicationinsights.azure.com/;LiveEndpoint=https://italynorth.livediagnostics.monitor.azure.com/;ApplicationId=21c18c79-257f-472f-b297-9ea0469de4b4"
  }
}